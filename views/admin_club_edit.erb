<h1><%== @club.full_name.presence || @club.name %></h1>

<% if @club.persisted? && @club.about_url %>
  <p><a href="/group/<%== make_value_safe_for_html_attribute(@club.name) %>">public page</a></p>
<% end %>

<form action="<%== @url %>" method="post" class="wide">
  <% unless @club.new_record? %>
    <input type="hidden" name="_method" value="patch"/>
  <% end %>
  <label>
    name:<br/>
    <input type="text" name="club[name]" value="<%== make_value_safe_for_html_attribute(@club.name) %>"/>
  </label>

  <label>
    profile URL:<br/>
    <input type="text" disabled value="<%== make_value_safe_for_html_attribute(@club.profile_url) %>"/>
  </label>

  <label>
    full name:<br/>
    <input type="text" name="club[full_name]" value="<%== make_value_safe_for_html_attribute(@club.full_name) %>"/>
  </label>

  <label>
    about URL:<br/>
    <input type="text" name="club[about_url]" value="<%== make_value_safe_for_html_attribute(@club.about_url) %>"/>
  </label>

  <label class="sub">
    <input type="checkbox" name="club[override_about_url]" value="true" <%= @club.override_about_url? && 'checked' %>> override (donʼt allow updating from profile URL)
  </label>

  <label>
    logo URL:<br/>
    <input type="text" name="club[logo_url]" value="<%== make_value_safe_for_html_attribute(@club.logo_url) %>"/>
  </label>

  <label class="sub">
    <input type="checkbox" name="club[override_logo_url]" value="true" <%= @club.override_logo_url? && 'checked' %>> override (donʼt allow updating from profile URL)
  </label>

  <% if @club.logo_url.present? %>
    <%= club_logo_image_tag(@club) %>
    <br/>
    <br/>
  <% end %>

  <label>
    description (<a href="https://www.markdownguide.org/cheat-sheet/" target="_new">Markdown</a> enabled):<br/>
    <textarea name="club[description]" rows="10"><%== @club.description %></textarea>
  </label>

  <label>
    net patterns:<br/>
    <textarea name="club[net_patterns]" rows="10"><%== JSON.pretty_generate(@club.net_patterns || []) %></textarea>
  </label>

  <label>
    additional net patterns (not overwritten by NetLogger data nightly):<br/>
    <textarea name="club[additional_net_patterns]" rows="10"><%== JSON.pretty_generate(@club.additional_net_patterns || []) %></textarea>
  </label>

  <label>
    net list:<br/>
    <textarea name="club[net_list]" rows="10"><%== JSON.pretty_generate(@club.net_list || []) %></textarea>
  </label>

  <label>
    <input type="checkbox" name="force_update_existing_nets" value="true"> force update existing nets
  </label>

  <input type="submit" value="Save"/>
</form>

<% if @club.persisted? %>
  <a name="members"></a>
  <h2>Members</h2>

  <% if @club_members.any? %>
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>Call Sign</th>
            <th>Name</th>
            <th>Joined</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @club_members.each do |club_member| %>
            <tr>
              <td><a href="/admin/users/<%== club_member.user.id %>"><%== club_member.user.call_sign %></a></td>
              <td><%== club_member.user.name %></td>
              <td><%= format_time(club_member.created_at) %></td>
              <td>
                <form class="inline" action="/admin/clubs/<%== @club.id %>/members/<%== club_member.user.id %>" method="post" onclick="if (!confirm('Are you sure?')) return false"><input type="hidden" name="_method" value="delete"/><button>Remove</button></form>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p><em>none</em></p>
  <% end %>

  <form action="/admin/clubs/<%== @club.id %>/members" method="post">
    <label>
      Call Sign:<br/>
      <input type="text" name="call_sign"/>
    </label>
    <input type="submit" value="Add"/>
  </form>

  <h2>Nets</h2>

  <a name="nets"></a>
  <% canonical_nets = @club.canonical_nets.order(:canonical_name) %>
  <% if canonical_nets.any? %>
    <ol>
      <% canonical_nets.each do |canonical_net| %>
        <li>
          <a href="/admin/canonical-nets/<%== canonical_net.id %>"><%== canonical_net.canonical_name %></a>
        </li>
      <% end %>
    </ol>
  <% else %>
    <p><em>none</em></p>
  <% end %>

  <div id="club-canonical-net-search" style="position: relative; max-width: 640px;">
    <p>Associate an existing canonical net with this club.</p>
    <label>
      Add net:<br/>
      <input type="text" id="canonical-net-search" placeholder="Type a canonical net name..." autocomplete="off" style="width: 420px;"/>
    </label>
    <div id="canonical-net-search-results" style="display: none; border: 1px solid #ccc; max-height: 240px; overflow-y: auto; background: white; position: absolute; z-index: 1000; width: 420px; box-shadow: 0 2px 5px rgba(0,0,0,0.2);"></div>

    <form action="/admin/clubs/<%== @club.id %>/canonical-nets" method="post" id="canonical-net-add-form" style="margin-top: 12px;">
      <input type="hidden" name="canonical_net_id" id="selected-canonical-net-id"/>
      <p id="selected-canonical-net" style="display:none;"></p>
      <button id="canonical-net-add-submit" disabled>Add net</button>
    </form>
  </div>

  <script>
    (() => {
      const container = document.getElementById('club-canonical-net-search')
      if (!container) return

      const input = document.getElementById('canonical-net-search')
      const resultsDiv = document.getElementById('canonical-net-search-results')
      const selectedDiv = document.getElementById('selected-canonical-net')
      const selectedIdInput = document.getElementById('selected-canonical-net-id')
      const submitButton = document.getElementById('canonical-net-add-submit')
      const excludedCanonicalNetIds = [<%= canonical_nets.map(&:id).join(',') %>].filter(Boolean)
      let searchTimeout

      const escapeHtml = (unsafe) => {
        const div = document.createElement('div')
        div.textContent = unsafe
        return div.innerHTML
      }

      const selectCanonicalNet = (canonicalNet) => {
        selectedIdInput.value = canonicalNet.id
        selectedDiv.innerHTML = `Selected: <strong>${escapeHtml(canonicalNet.canonical_name)}</strong>`
        selectedDiv.style.display = 'block'
        submitButton.disabled = false
        input.value = canonicalNet.canonical_name
        resultsDiv.style.display = 'none'
      }

      input.addEventListener('input', (event) => {
        const query = event.target.value.trim()
        selectedIdInput.value = ''
        selectedDiv.style.display = 'none'
        submitButton.disabled = true

        clearTimeout(searchTimeout)

        if (query.length < 2) {
          resultsDiv.style.display = 'none'
          return
        }

        searchTimeout = setTimeout(() => {
          const searchParams = new URLSearchParams({ q: query })
          if (excludedCanonicalNetIds.length > 0) {
            searchParams.set('exclude_ids', excludedCanonicalNetIds.join(','))
          }

          fetch(`/api/admin/canonical-nets/search?${searchParams.toString()}`)
            .then(response => response.json())
            .then(canonicalNets => {
              if (canonicalNets.length === 0) {
                resultsDiv.innerHTML = '<div style="padding: 10px; color: #666;">No canonical nets found</div>'
              } else {
                resultsDiv.innerHTML = canonicalNets.map(canonicalNet => `
                  <div
                    style="padding: 10px; cursor: pointer; border-bottom: 1px solid #eee;"
                    data-canonical-net='${JSON.stringify(canonicalNet).replace(/'/g, '&#39;')}'
                    onmouseover="this.style.backgroundColor='#f5f5f5'"
                    onmouseout="this.style.backgroundColor='white'">
                    <strong>${escapeHtml(canonicalNet.canonical_name)}</strong>
                    <br/>
                    <small>${canonicalNet.active_count} active, ${canonicalNet.closed_count} closed</small>
                    ${canonicalNet.aliases.length > 0 ? `<br/><small style="color:#666">${escapeHtml(canonicalNet.aliases.join(', '))}</small>` : ''}
                  </div>
                `).join('')

                resultsDiv.querySelectorAll('[data-canonical-net]').forEach((elm) => {
                  elm.addEventListener('click', () => {
                    selectCanonicalNet(JSON.parse(elm.getAttribute('data-canonical-net')))
                  })
                })
              }
              resultsDiv.style.display = 'block'
            })
        }, 250)
      })

      document.addEventListener('click', (event) => {
        if (!event.target.closest('#club-canonical-net-search')) {
          resultsDiv.style.display = 'none'
        }
      })
    })()
  </script>
<% end %>
